{% comment %}
  Renders a product card.
  Usage: {% render 'product-card', product: product %}
  Pass placeholder_index (1-6) when product is nil to show a placeholder.
{% endcomment %}

{%- if product != nil -%}
  {%- assign has_discount = false -%}
  {%- if product.compare_at_price > product.price -%}
    {%- assign has_discount = true -%}
    {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round -%}
  {%- endif -%}

  <div class="product__card-app">
    {%- if has_discount -%}
      <span class="discount__card-app">-{{ discount_pct }}%</span>
    {%- endif -%}
    <button class="btn-wishlist-card" data-product-handle="{{ product.handle }}" aria-label="Agregar a favoritos">
      <svg class="icon" aria-hidden="true"><use href="#icon-heart"></use></svg>
    </button>
    <figure class="img__container__card-app">
      <a href="{{ product.url }}" tabindex="-1" aria-hidden="true">
        {%- if product.featured_image != blank -%}
          <img
            src="{{ product.featured_image | image_url: width: 460 }}"
            alt="{{ product.featured_image.alt | escape }}"
            class="img__card-app"
            loading="lazy"
            width="230"
            height="170"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg img__card-app' }}
        {%- endif -%}
      </a>
      <a href="{{ product.url }}">
        <h4 class="card-app-title">{{ product.title }}</h4>
      </a>
      <p class="card-app-description">{{ product.description | strip_html | truncate: 70 }}</p>
      <span class="price__card-app">
        {{ product.price | money }}
        {%- if has_discount -%}
          <span class="original-price__card-app">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </span>
    </figure>
    <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <input type="hidden" name="return_to" value="{{ request.path }}">
      <button type="submit" class="btn__card-app" name="add">
        <svg class="icon shopping-icon__card-app" aria-hidden="true"><use href="#icon-cart3"></use></svg>
        Agregar al carrito
      </button>
    </form>
  </div>

{%- else -%}
  {%- assign p_idx = placeholder_index | default: 1 -%}
  <div class="product__card-app">
    <span class="discount__card-app">-25%</span>
    <figure class="img__container__card-app">
      {{ 'product-' | append: p_idx | placeholder_svg_tag: 'placeholder-svg img__card-app' }}
      <h4 class="card-app-title">Producto de ejemplo</h4>
      <p class="card-app-description">Descripción breve del producto<br>SKU: EJEMPLO-00{{ p_idx }}</p>
      <span class="price__card-app">$1,000.00 <span class="original-price__card-app">$1,333.00</span></span>
    </figure>
    <button class="btn__card-app" disabled>
      <svg class="icon shopping-icon__card-app" aria-hidden="true"><use href="#icon-cart3"></use></svg>
      Agregar al carrito
    </button>
  </div>
{%- endif -%}
