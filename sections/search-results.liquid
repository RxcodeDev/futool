{%- paginate search.results by 24 -%}
<div class="search-page">

  <div class="search-page__header">
    {%- if search.performed -%}
      <p class="search-page__count">
        {%- if search.results_count == 0 -%}
          Sin resultados para <strong>"{{ search.terms | escape }}"</strong>
        {%- else -%}
          {{ search.results_count }} resultado{% if search.results_count != 1 %}s{% endif %} para <strong>"{{ search.terms | escape }}"</strong>
        {%- endif -%}
      </p>
    {%- endif -%}
  </div>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <div class="search-page__empty">
        <p>No encontramos productos para tu búsqueda.</p>
        <p>Intenta con otras palabras clave o revisa la ortografía.</p>
      </div>
    {%- else -%}
      <div class="search-results-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {%- render 'product-card', product: item -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Paginación de resultados">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="pagination__btn">← Anterior</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="pagination__btn">{{ part.title }}</a>
            {%- else -%}
              {%- if part.title == paginate.current_page -%}
                <span class="pagination__btn pagination__btn--active">{{ part.title }}</span>
              {%- else -%}
                <span class="pagination__btn pagination__ellipsis">{{ part.title }}</span>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="pagination__btn">Siguiente →</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endif -%}
  {%- else -%}
    <p class="search-page__hint">Escribe lo que buscas arriba y presiona <strong>Buscar</strong>.</p>
  {%- endif -%}

</div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Resultados de búsqueda",
  "settings": [],
  "presets": [{ "name": "Resultados de búsqueda" }]
}
{% endschema %}
