<article class="mercadolibre">
  <a
    href="{{ section.settings.url | default: '#' }}"
    target="_blank"
    rel="noopener noreferrer"
  >
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        alt="{{ section.settings.image.alt | default: 'Visita nuestra tienda en Mercado Libre' | escape }}"
        loading="lazy"
      >
    {%- else -%}
      <picture>
        <source srcset="{{ 'banner-mercado-libre.webp' | asset_url }}" type="image/webp">
        <img
          src="{{ 'banner-mercado-libre.jpg' | asset_url }}"
          alt="Visita nuestra tienda en Mercado Libre"
          loading="lazy"
        >
      </picture>
    {%- endif -%}
  </a>
</article>

{% schema %}
{
  "name": "Banner Mercado Libre",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen del banner"
    },
    {
      "type": "url",
      "id": "url",
      "label": "URL de la tienda en Mercado Libre"
    }
  ],
  "presets": [
    {
      "name": "Banner Mercado Libre"
    }
  ]
}
{% endschema %}
