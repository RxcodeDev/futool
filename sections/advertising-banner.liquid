<section class="advertising">
  {%- liquid
    if section.settings.image != blank
      assign adv_src  = section.settings.image | image_url: width: 1920
      assign adv_alt  = section.settings.image.alt | escape
      assign adv_webp = blank
    else
      assign adv_src  = 'banner-nuevo-producto.jpg' | asset_url
      assign adv_alt  = 'Banner publicitario'
      assign adv_webp = 'banner-nuevo-producto.webp' | asset_url
    endif
    assign adv_link = section.settings.link
  -%}
  {%- if adv_link != blank -%}<a href="{{ adv_link }}">{%- endif -%}
  <picture>
    {%- if adv_webp != blank -%}
      <source srcset="{{ adv_webp }}" type="image/webp">
    {%- endif -%}
    <img src="{{ adv_src }}" alt="{{ adv_alt }}" class="advertising__img" loading="lazy">
  </picture>
  {%- if adv_link != blank -%}</a>{%- endif -%}
</section>

{% schema %}
{
  "name": "Banner Publicitario",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen del banner"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Enlace (opcional)"
    }
  ],
  "presets": [
    {
      "name": "Banner Publicitario"
    }
  ]
}
{% endschema %}
