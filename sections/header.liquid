<header class="navigation">
  <div class="nav-inner">

    <div class="search__navigation">
      <a href="{{ routes.root_url }}" class="logo-link">
        {%- if section.settings.logo != blank -%}
          <img
            class="img__search"
            src="{{ section.settings.logo | image_url: width: 300 }}"
            alt="{{ shop.name }}"
          >
        {%- else -%}
          <img class="img__search" src="{{ 'logoHorizontal.png' | asset_url }}" alt="{{ shop.name }}">
        {%- endif -%}
      </a>
      <form action="{{ routes.search_url }}" method="get" class="input-wrapper__search" role="search">
        <input
          type="text"
          name="q"
          id="search-input"
          placeholder="Buscar producto..."
          value="{{ search.terms | escape }}"
          autocomplete="off"
        >
        <button type="submit" class="btn-search__navigation" aria-label="Buscar">
          <svg class="icon" aria-hidden="true"><use href="#icon-search"></use></svg>
        </button>
      </form>
    </div>

    <div class="actions__navigation">
      <a href="{{ section.settings.billing_url }}" class="billing-link__nav">Facturación</a>
      <a href="/pages/wishlist" aria-label="Favoritos">
        <svg class="icon" aria-hidden="true"><use href="#icon-heart"></use></svg>
      </a>
      <a href="{{ routes.cart_url }}" aria-label="Carrito" class="cart-link__nav">
        <svg class="icon" aria-hidden="true"><use href="#icon-cart3"></use></svg>
        <span id="cart-count-badge" style="display:none">0</span>
      </a>
      <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" aria-label="Cuenta">
        <svg class="icon" aria-hidden="true"><use href="#icon-person"></use></svg>
      </a>
      <button class="hamburger__nav" aria-label="Menú" aria-expanded="false" aria-controls="mobile-nav">
        <span></span><span></span><span></span>
      </button>
    </div>

    <nav class="categories__navigation" aria-label="Navegación principal">
      <ul>
        <li class="has-dropdown">
          <a href="/collections">MAQUINARIAS</a>
          <ul class="dropdown__nav">
            {%- for col in collections -%}
              {%- assign col_title_lower = col.title | downcase -%}
              {%- if col_title_lower contains 'maquinaria' -%}
                <li><a href="{{ col.url }}">{{ col.title }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </li>
        <li class="has-dropdown">
          <a href="/collections">REFACCIONES</a>
          <ul class="dropdown__nav">
            {%- for col in collections -%}
              {%- assign col_title_lower = col.title | downcase -%}
              {%- if col_title_lower contains 'refaccion' -%}
                <li><a href="{{ col.url }}">{{ col.title }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </li>
        <li><a href="/pages/nuestras-marcas">NUESTRAS MARCAS</a></li>
        <li><a href="/pages/preguntas-y-respuestas">PREGUNTAS Y RESPUESTAS</a></li>
        <li><a href="/pages/distribuidores">DISTRIBUIDORES</a></li>
      </ul>
    </nav>

  </div>

  <!-- Mobile nav drawer -->
  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul>
      <li class="mobile-nav__item has-children">
        <a href="/collections">Maquinarias</a>
        <ul class="mobile-nav__sub">
          {%- for col in collections -%}
            {%- assign col_title_lower = col.title | downcase -%}
            {%- if col_title_lower contains 'maquinaria' -%}
              <li><a href="{{ col.url }}">{{ col.title }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </li>
      <li class="mobile-nav__item has-children">
        <a href="/collections">Refacciones</a>
        <ul class="mobile-nav__sub">
          {%- for col in collections -%}
            {%- assign col_title_lower = col.title | downcase -%}
            {%- if col_title_lower contains 'refaccion' -%}
              <li><a href="{{ col.url }}">{{ col.title }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </li>
      <li class="mobile-nav__item"><a href="/pages/nuestras-marcas">Nuestras Marcas</a></li>
      <li class="mobile-nav__item"><a href="/pages/preguntas-y-respuestas">Preguntas y Respuestas</a></li>
      <li class="mobile-nav__item"><a href="/pages/distribuidores">Distribuidores</a></li>
    </ul>
  </nav>
</header>

<script>
(function() {
  var btn = document.querySelector('.hamburger__nav');
  var nav = document.getElementById('mobile-nav');
  if (!btn || !nav) return;
  btn.addEventListener('click', function() {
    var open = nav.classList.toggle('is-open');
    btn.classList.toggle('is-open', open);
    btn.setAttribute('aria-expanded', open);
    nav.setAttribute('aria-hidden', !open);
  });

  // Expansión de barra de búsqueda en móvil
  var searchInput = document.getElementById('search-input');
  var searchWrapper = searchInput ? searchInput.closest('.input-wrapper__search') : null;
  var navInner = document.querySelector('.nav-inner');
  if (searchInput && searchWrapper && navInner) {
    searchInput.addEventListener('focus', function() {
      navInner.classList.add('search-expanded');
    });
    searchInput.addEventListener('blur', function() {
      navInner.classList.remove('search-expanded');
    });
  }
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo horizontal"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú de navegación",
      "default": "main-menu"
    },
    {
      "type": "url",
      "id": "billing_url",
      "label": "URL de Facturación"
    }
  ]
}
{% endschema %}
