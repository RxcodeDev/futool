<div class="list-collections-page">
  <h1 class="list-collections-title">Todas las colecciones</h1>
  <div class="list-collections-grid">
    {%- for collection in collections -%}
      <a href="{{ collection.url }}" class="collection-card">
        <div class="collection-card-img">
          {%- if collection.image -%}
            <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.image.alt | default: collection.title | escape }}" loading="lazy">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="collection-card-info">
          <h2 class="collection-card-title">{{ collection.title }}</h2>
          <span class="collection-card-count">{{ collection.products_count }} productos</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Lista de Colecciones",
  "settings": [],
  "presets": [{ "name": "Lista de Colecciones" }]
}
{% endschema %}
