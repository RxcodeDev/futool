<footer class="footer">

  <!-- Left column: info + social/payments -->
  <div class="content__footer">

    <div class="info__content-footer">

      <!-- Brand & contact -->
      <div class="brand-col__footer">
        {%- if section.settings.logo_vertical != blank -%}
          <img
            src="{{ section.settings.logo_vertical | image_url: width: 200 }}"
            alt="{{ shop.name }}"
            class="logo__footer"
          >
        {%- else -%}
          <img src="{{ 'logoVertical.png' | asset_url }}" alt="{{ shop.name }}" class="logo__footer">
        {%- endif -%}

        {%- if section.settings.phone_1 != blank or section.settings.phone_2 != blank -%}
          <div class="contact-group__footer">
            <p class="contact-label__footer">Teléfono.</p>
            {%- if section.settings.phone_1 != blank -%}<p>{{ section.settings.phone_1 }}</p>{%- endif -%}
            {%- if section.settings.phone_2 != blank -%}<p>{{ section.settings.phone_2 }}</p>{%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.whatsapp_1 != blank or section.settings.whatsapp_2 != blank -%}
          <div class="contact-group__footer">
            <p class="contact-label__footer">WhatsApp.</p>
            {%- if section.settings.whatsapp_1 != blank -%}<p>{{ section.settings.whatsapp_1 }}</p>{%- endif -%}
            {%- if section.settings.whatsapp_2 != blank -%}<p>{{ section.settings.whatsapp_2 }}</p>{%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Info links -->
      <div class="links-col__footer">
        <p class="col-title__footer">INFORMACIÓN</p>
        {%- if linklists[section.settings.info_menu].links.size > 0 -%}
          {%- for link in linklists[section.settings.info_menu].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="/pages/politica-de-ventas">Politica de ventas</a>
          <a href="/pages/politica-de-cookies">Politica de cookies</a>
          <a href="/pages/aviso-de-privacidad">Aviso de privacidad</a>
          <a href="/pages/proceso-de-compra">Proceso de compra</a>
        {%- endif -%}

        <p class="col-title__footer">FORMAS DE PAGO</p>
        {%- if linklists[section.settings.payment_menu].links.size > 0 -%}
          {%- for link in linklists[section.settings.payment_menu].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="#">Los pagos serán procesados mediante la pasarela de Openpay.</a>
          <a href="#">Los pagos serán procesados mediante la pasarela de Mercado pago.</a>
        {%- endif -%}

        <p class="col-title__footer">FACTURACIÓN</p>
        {%- if linklists[section.settings.billing_menu].links.size > 0 -%}
          {%- for link in linklists[section.settings.billing_menu].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="#">La facturación se realizará conforme a las políticas establecidas.</a>
        {%- endif -%}
      </div>

      <!-- Customer attention -->
      <div class="attention-col__footer">
        <p class="col-title__footer">Atención al cliente</p>
        {%- if section.settings.attention_hours != blank -%}
          <p>{{ section.settings.attention_hours }}</p>
        {%- endif -%}
        {%- if section.settings.attention_saturday != blank -%}
          <p>{{ section.settings.attention_saturday }}</p>
        {%- endif -%}
        {%- if section.settings.email != blank -%}
          <p>{{ section.settings.email | downcase }}</p>
        {%- endif -%}
      </div>
    </div>

    <!-- Catalog banner -->
    <div class="catalog-banner__footer">
      <span>AQUÍ DESCARGA LOS</span>
      <span><span>NUEVOS</span> CATÁLOGOS</span>
    </div>

    <!-- Social & Payment methods -->
    <div class="pays-method__footer">
      <div class="social__footer">
        <a href="{{ section.settings.whatsapp_link | default: '#' }}" aria-label="WhatsApp"{% if section.settings.whatsapp_link != blank %} target="_blank" rel="noopener noreferrer"{% endif %}>
          <svg class="social-icon__footer" aria-hidden="true"><use href="#icon-whatsapp"></use></svg>
        </a>
        <a href="{{ section.settings.facebook_link | default: '#' }}" aria-label="Facebook"{% if section.settings.facebook_link != blank %} target="_blank" rel="noopener noreferrer"{% endif %}>
          <svg class="social-icon__footer" aria-hidden="true"><use href="#icon-facebook"></use></svg>
        </a>
        <a href="{{ section.settings.instagram_link | default: '#' }}" aria-label="Instagram"{% if section.settings.instagram_link != blank %} target="_blank" rel="noopener noreferrer"{% endif %}>
          <svg class="social-icon__footer" aria-hidden="true"><use href="#icon-instagram"></use></svg>
        </a>
        <a href="{{ section.settings.tiktok_link | default: '#' }}" aria-label="TikTok"{% if section.settings.tiktok_link != blank %} target="_blank" rel="noopener noreferrer"{% endif %}>
          <svg class="social-icon__footer" aria-hidden="true"><use href="#icon-tiktok"></use></svg>
        </a>
      </div>
      <div class="payments__footer">
        {%- if section.settings.show_visa -%}
          <svg class="payment-icon__footer" role="img" aria-label="VISA"><use href="#icon-pay-visa"></use></svg>
        {%- endif -%}
        {%- if section.settings.show_mastercard -%}
          <svg class="payment-icon__footer" role="img" aria-label="MasterCard"><use href="#icon-pay-mastercard"></use></svg>
        {%- endif -%}
        {%- if section.settings.show_amex -%}
          <svg class="payment-icon__footer" role="img" aria-label="American Express"><use href="#icon-pay-amex"></use></svg>
        {%- endif -%}
        {%- if section.settings.show_oxxo -%}
          <svg class="payment-icon__footer" role="img" aria-label="OXXO Pay"><use href="#icon-pay-oxxo"></use></svg>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Right column: catalog PDFs -->
  <div class="content__footer --catalog-layout">

    <!-- Copia visible en móvil -->
    <div class="catalog-banner__footer catalog-banner--mobile-only">
      <span>AQUÍ DESCARGA LOS</span>
      <span><span>NUEVOS</span> CATÁLOGOS</span>
    </div>

    <div class="item__catalog-footer">
      <a
        href="{% if section.settings.catalog_1_file != blank %}{{ section.settings.catalog_1_file }}{% else %}{{ 'maquinaria.pdf' | asset_url }}{% endif %}"
        download="{{ section.settings.catalog_1_download_name | default: 'Catalogo-Maquinaria-2026.pdf' }}"
      >
        {%- if section.settings.catalog_1_image != blank -%}
          <img
            src="{{ section.settings.catalog_1_image | image_url: width: 400 }}"
            alt="{{ section.settings.catalog_1_image.alt | default: 'Catálogo Maquinaria 2026' | escape }}"
            class="catalog-img__footer"
            loading="lazy"
          >
        {%- else -%}
          <img
            src="{{ 'maquinaria.jpg' | asset_url }}"
            alt="Catálogo Maquinaria 2026"
            class="catalog-img__footer"
            loading="lazy"
          >
        {%- endif -%}
      </a>
    </div>
    <div class="item__catalog-footer">
      <a
        href="{% if section.settings.catalog_2_file != blank %}{{ section.settings.catalog_2_file }}{% else %}{{ 'refacciones.pdf' | asset_url }}{% endif %}"
        download="{{ section.settings.catalog_2_download_name | default: 'Catalogo-Refacciones-2026.pdf' }}"
      >
        {%- if section.settings.catalog_2_image != blank -%}
          <img
            src="{{ section.settings.catalog_2_image | image_url: width: 400 }}"
            alt="{{ section.settings.catalog_2_image.alt | default: 'Catálogo Refacciones 2026' | escape }}"
            class="catalog-img__footer"
            loading="lazy"
          >
        {%- else -%}
          <img
            src="{{ 'refacciones.jpg' | asset_url }}"
            alt="Catálogo Refacciones 2026"
            class="catalog-img__footer"
            loading="lazy"
          >
        {%- endif -%}
      </a>
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="bottom__footer">
    <p>{{ section.settings.copyright_text }}</p>
  </div>

</footer>

<script>
(function() {
  if (window.innerWidth <= 640) {
    var btn = document.querySelector('.catalog-banner__footer:not(.catalog-banner--mobile-only)');
    if (btn) btn.style.display = 'none';
  }
})();
</script>

