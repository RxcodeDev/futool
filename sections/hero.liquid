<div class="hero">
  <div class="banner__hero">
    {%- if section.settings.hero_image != blank -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1920 }}"
        alt="{{ section.settings.hero_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="categories__hero">
    {%- for block in section.blocks -%}
      <a
        class="card__categories"
        href="{{ block.settings.link | default: '#' }}"
        {{ block.shopify_attributes }}
      >
        <div class="header__card-categories">
          <h3>{{ block.settings.title }}</h3>
        </div>
        <div class="body__card-categories">
          {%- if block.settings.image != blank -%}
            <img
              class="img__card-categories"
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="{{ block.settings.title | escape }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg img__card-categories' }}
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Imagen del banner principal"
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Tarjeta de categoría",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "CATEGORÍA"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "category_card", "settings": { "title": "DESBROZADORAS" } },
        { "type": "category_card", "settings": { "title": "REFACCIONES" } },
        { "type": "category_card", "settings": { "title": "PODADORAS" } },
        { "type": "category_card", "settings": { "title": "MOTOSIERRAS" } },
        { "type": "category_card", "settings": { "title": "ASPERSORES" } },
        { "type": "category_card", "settings": { "title": "MOTOBOMBAS" } }
      ]
    }
  ]
}
{% endschema %}
