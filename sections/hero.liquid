{%- assign category_blocks = section.blocks | where: 'type', 'category_card' -%}

{%- comment -%} Resolver URLs de colecciones igual que el nav {%- endcomment -%}
{%- assign hero_maq_col = blank -%}
{%- assign hero_ref_url = '/collections/all' -%}
{%- for _col in collections -%}
  {%- assign _col_lower = _col.title | downcase -%}
  {%- if _col_lower contains 'maquinaria' and hero_maq_col == blank -%}
    {%- assign hero_maq_col = _col -%}
  {%- endif -%}
  {%- if _col_lower contains 'refaccion' and hero_ref_url == '/collections/all' -%}
    {%- assign hero_ref_url = _col.url -%}
  {%- endif -%}
{%- endfor -%}
{%- assign hero_maq_url = hero_maq_col.url | default: '/collections/maquinaria' -%}

{%- comment -%} Banner slides: slug|label (solo imágenes banner-*) {%- endcomment -%}
{%- assign banner_slides = 'desbrozadora|Desbrozadoras,podadora|Podadoras,aspersores|Aspersores' | split: ',' -%}

{%- comment -%} Categorías: slug_carrusel|has_webp|título|tipo(maq/ref)|tag {%- endcomment -%}
{%- assign category_data = 'desbrozadora|1|DESBROZADORAS|maq|Desbrozadoras,refacciones-generales|0|REFACCIONES|ref|,podadora|0|PODADORAS|maq|Podadoras,motosierra|1|MOTOSIERRAS|maq|Motosierras,aspersor|1|ASPERSORES|maq|Aspersoras,motobomba|1|MOTOBOMBAS|maq|Motobombas,compresor|1|COMPRESORES|maq|Compresores,generador|1|GENERADORES|maq|Generadores,hidrolavadora|1|HIDROLAVADORAS|maq|Hidrolavadoras,motaladros|1|MOTOLADROS|maq|Motoladros,motocultor|1|MOTOCULTORES|maq|Motocultores,motor|1|MOTORES|maq|Motores,parihuela|0|PARIHUELA|maq|Parihuela,sopladora|0|SOPLADORAS|maq|Sopladoras,trituradora|0|TRITURADORAS|maq|Trituradoras' | split: ',' -%}

<div class="hero">
  <div class="hero-slider" id="hero-slider">

    <div class="hero-track" id="hero-track">
      {%- for item in banner_slides -%}
        {%- assign parts = item | split: '|' -%}
        {%- assign slug = parts[0] -%}
        {%- assign slide_label = parts[1] -%}
        <div class="hero-slide">
          <picture>
            <source srcset="{{ 'banner-' | append: slug | append: '.webp' | asset_url }}" type="image/webp">
            <img
              src="{{ 'banner-' | append: slug | append: '.jpg' | asset_url }}"
              alt="{{ slide_label }}"
              {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
            >
          </picture>
        </div>
      {%- endfor -%}
    </div>

    <button class="hero-prev" id="hero-prev" aria-label="Anterior">&#8249;</button>
    <button class="hero-next" id="hero-next" aria-label="Siguiente">&#8250;</button>

    <div class="hero-slider__dots" id="hero-dots">
      {%- for item in banner_slides -%}
        <button
          class="hero-dot{% if forloop.first %} is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          aria-label="Diapositiva {{ forloop.index }}"
        ></button>
      {%- endfor -%}
    </div>

  </div>

  <div class="categories__hero">
    <button class="cat-btn cat-btn-prev" id="cat-prev" aria-label="Anterior">&#8249;</button>
    <div class="cat-viewport">
    <div class="cat-track" id="cat-track">
    {%- for item in category_data -%}
      {%- assign cparts = item | split: '|' -%}
      {%- assign cslug = cparts[0] -%}
      {%- assign cwebp = cparts[1] -%}
      {%- assign ctitle = cparts[2] -%}
      {%- comment -%} Buscar bloque con el mismo título para obtener el link {%- endcomment -%}
      {%- assign ctype = cparts[3] -%}
      {%- assign ctag  = cparts[4] -%}
      {%- if ctype == 'ref' -%}
        {%- assign clink = hero_ref_url -%}
      {%- elsif ctag != blank -%}
        {%- assign clink = hero_maq_url | append: '/' | append: ctag -%}
      {%- else -%}
        {%- assign clink = hero_maq_url -%}
      {%- endif -%}
      <a class="card__categories" href="{{ clink }}">
        <div class="header__card-categories">
          <h3>{{ ctitle }}</h3>
        </div>
        <div class="body__card-categories">
          {%- if cwebp == '1' -%}
            <picture>
              <source srcset="{{ 'carrusel-' | append: cslug | append: '.webp' | asset_url }}" type="image/webp">
              <img
                class="img__card-categories"
                src="{{ 'carrusel-' | append: cslug | append: '.jpg' | asset_url }}"
                alt="{{ ctitle }}"
                loading="lazy"
              >
            </picture>
          {%- else -%}
            <img
              class="img__card-categories"
              src="{{ 'carrusel-' | append: cslug | append: '.jpg' | asset_url }}"
              alt="{{ ctitle }}"
              loading="lazy"
            >
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
    </div>
    </div>
    <button class="cat-btn cat-btn-next" id="cat-next" aria-label="Siguiente">&#8250;</button>
  </div>
</div>

<script>
(function () {
  var slider = document.getElementById('hero-slider');
  var track = document.getElementById('hero-track');
  if (!slider || !track) return;

  var origSlides = Array.from(track.querySelectorAll('.hero-slide'));
  var total = origSlides.length;
  if (total === 0) return;

  // Clone last slide and prepend; clone first slide and append (for infinite loop)
  var firstClone = origSlides[0].cloneNode(true);
  var lastClone = origSlides[total - 1].cloneNode(true);
  firstClone.setAttribute('aria-hidden', 'true');
  lastClone.setAttribute('aria-hidden', 'true');
  track.appendChild(firstClone);
  track.insertBefore(lastClone, origSlides[0]);

  var current = 1; // real first slide is at index 1 (after the cloned last)
  var isTransitioning = false;
  var timer;
  var dots = Array.from(document.querySelectorAll('.hero-dot'));

  function setPos(index, animate) {
    track.style.transition = animate ? 'transform 0.7s ease' : 'none';
    track.style.transform = 'translateX(-' + (index * 100) + '%)';
  }

  function updateDots(realIndex) {
    dots.forEach(function (dot, i) {
      dot.classList.toggle('is-active', i === realIndex);
    });
  }

  function goTo(index) {
    if (isTransitioning) return;
    isTransitioning = true;
    current = index;
    setPos(current, true);
    updateDots((current - 1 + total) % total);
  }

  track.addEventListener('transitionend', function () {
    isTransitioning = false;
    if (current <= 0) {
      current = total;
      setPos(current, false);
    } else if (current >= total + 1) {
      current = 1;
      setPos(current, false);
    }
    updateDots((current - 1 + total) % total);
  });

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }

  setPos(current, false);
  updateDots(0);

  dots.forEach(function (dot, i) {
    dot.addEventListener('click', function () {
      clearInterval(timer);
      goTo(i + 1);
      startTimer();
    });
  });

  var prevBtn = document.getElementById('hero-prev');
  var nextBtn = document.getElementById('hero-next');
  if (prevBtn) prevBtn.addEventListener('click', function () { clearInterval(timer); prev(); startTimer(); });
  if (nextBtn) nextBtn.addEventListener('click', function () { clearInterval(timer); next(); startTimer(); });

  // Touch / swipe support
  var touchX = 0;
  slider.addEventListener('touchstart', function (e) { touchX = e.touches[0].clientX; }, { passive: true });
  slider.addEventListener('touchend', function (e) {
    var diff = touchX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) { clearInterval(timer); diff > 0 ? next() : prev(); startTimer(); }
  });

  function startTimer() {
    clearInterval(timer);
    timer = setInterval(next, 5000);
  }

  startTimer();
})();

// ── Mobile: ciclo infinito de categorías (fade escalonado) ──
(function () {
  if (window.innerWidth > 768) return;
  var track = document.getElementById('cat-track');
  if (!track) return;
  var cards = Array.from(track.querySelectorAll('.card__categories'));
  if (cards.length <= 6) return;

  // Shuffle inicial Fisher-Yates
  for (var i = cards.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var tmp = cards[i]; cards[i] = cards[j]; cards[j] = tmp;
  }
  cards.forEach(function (c) { track.appendChild(c); });

  // Estado inicial: mostrar primeras 6, ocultar el resto
  cards.forEach(function (c, i) {
    c.style.transition = 'opacity 0.4s ease';
    if (i >= 6) c.classList.add('cat-hidden');
  });

  var offset = 0;

  setInterval(function () {
    var visible = [];
    for (var i = 0; i < 6; i++) visible.push(cards[(offset + i) % cards.length]);

    // Fade out escalonado (80ms entre cada carta)
    visible.forEach(function (c, i) {
      setTimeout(function () { c.style.opacity = '0'; }, i * 80);
    });

    setTimeout(function () {
      // Ocultar actuales y preparar las siguientes 6
      visible.forEach(function (c) { c.classList.add('cat-hidden'); });
      offset = (offset + 3) % cards.length;
      var next = [];
      for (var i = 0; i < 6; i++) next.push(cards[(offset + i) % cards.length]);
      next.forEach(function (c) { c.classList.remove('cat-hidden'); c.style.opacity = '0'; });

      // Fade in escalonado (100ms entre cada carta)
      next.forEach(function (c, i) {
        setTimeout(function () { c.style.opacity = '1'; }, 60 + i * 100);
      });
    }, 6 * 80 + 400);
  }, 5000);
})();

// ── Category carousel buttons ──
(function () {
  var track = document.getElementById('cat-track');
  var prevBtn = document.getElementById('cat-prev');
  var nextBtn = document.getElementById('cat-next');
  if (!track || !prevBtn || !nextBtn) return;
  var cards = track.querySelectorAll('.card__categories');
  if (!cards.length) return;
  var current = 0;
  function cardW() { return cards[0].offsetWidth + 11; } // 11 = gap ~0.7rem
  function visible() { return Math.round(track.parentElement.offsetWidth / cardW()); }
  function update() {
    track.style.transform = 'translateX(-' + (current * cardW()) + 'px)';
    prevBtn.style.opacity = current <= 0 ? '0.3' : '1';
    nextBtn.style.opacity = current >= cards.length - visible() ? '0.3' : '1';
  }
  prevBtn.addEventListener('click', function () { if (current > 0) { current--; update(); } });
  nextBtn.addEventListener('click', function () { if (current < cards.length - visible()) { current++; update(); } });
  window.addEventListener('resize', function () { current = 0; update(); });
  update();
})();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [],
  "blocks": [
    {
      "type": "category_card",
      "name": "Tarjeta de categoría",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "CATEGORÍA"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "category_card", "settings": { "title": "DESBROZADORAS" } },
        { "type": "category_card", "settings": { "title": "REFACCIONES" } },
        { "type": "category_card", "settings": { "title": "PODADORAS" } },
        { "type": "category_card", "settings": { "title": "MOTOSIERRAS" } },
        { "type": "category_card", "settings": { "title": "ASPERSORES" } },
        { "type": "category_card", "settings": { "title": "MOTOBOMBAS" } }
      ]
    }
  ]
}
{% endschema %}
