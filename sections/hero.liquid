{%- assign category_blocks = section.blocks | where: 'type', 'category_card' -%}

{%- comment -%} Slides: slug|has_webp|label {%- endcomment -%}
{%- assign slides_raw = 'desbrozadora|1|Desbrozadoras,podadora|0|Podadoras,motosierra|1|Motosierras,aspersor|1|Aspersores,motobomba|1|Motobombas,compresor|1|Compresores,generador|1|Generadores,hidrolavadora|1|Hidrolavadoras,motaladros|1|Motaladros,motocultor|1|Motocultores,motor|1|Motores,parihuela|0|Parihuelas,refacciones-generales|0|Refacciones Generales,sopladora|0|Sopladoras,trituradora|0|Trituradoras' | split: ',' -%}

<div class="hero">
  <div class="hero-slider" id="hero-slider">

    <div class="hero-track" id="hero-track">
      {%- for item in slides_raw -%}
        {%- assign parts = item | split: '|' -%}
        {%- assign slug = parts[0] -%}
        {%- assign has_webp = parts[1] -%}
        {%- assign slide_label = parts[2] -%}
        <div class="hero-slide">
          {%- if has_webp == '1' -%}
            <picture>
              <source srcset="{{ 'carrusel-' | append: slug | append: '.webp' | asset_url }}" type="image/webp">
              <img
                src="{{ 'carrusel-' | append: slug | append: '.jpg' | asset_url }}"
                alt="{{ slide_label }}"
                {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
              >
            </picture>
          {%- else -%}
            <img
              src="{{ 'carrusel-' | append: slug | append: '.jpg' | asset_url }}"
              alt="{{ slide_label }}"
              {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
            >
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <button class="hero-prev" id="hero-prev" aria-label="Anterior">&#8249;</button>
    <button class="hero-next" id="hero-next" aria-label="Siguiente">&#8250;</button>

    <div class="hero-slider__dots" id="hero-dots">
      {%- for item in slides_raw -%}
        <button
          class="hero-dot{% if forloop.first %} is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          aria-label="Diapositiva {{ forloop.index }}"
        ></button>
      {%- endfor -%}
    </div>

  </div>

  <div class="categories__hero">
    {%- for block in category_blocks -%}
      <a
        class="card__categories"
        href="{{ block.settings.link | default: '#' }}"
        {{ block.shopify_attributes }}
      >
        <div class="header__card-categories">
          <h3>{{ block.settings.title }}</h3>
        </div>
        <div class="body__card-categories">
          {%- if block.settings.image != blank -%}
            <img
              class="img__card-categories"
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="{{ block.settings.title | escape }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg img__card-categories' }}
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

<script>
(function () {
  var slider = document.getElementById('hero-slider');
  var track = document.getElementById('hero-track');
  if (!slider || !track) return;

  var origSlides = Array.from(track.querySelectorAll('.hero-slide'));
  var total = origSlides.length;
  if (total === 0) return;

  // Clone last slide and prepend; clone first slide and append (for infinite loop)
  var firstClone = origSlides[0].cloneNode(true);
  var lastClone = origSlides[total - 1].cloneNode(true);
  firstClone.setAttribute('aria-hidden', 'true');
  lastClone.setAttribute('aria-hidden', 'true');
  track.appendChild(firstClone);
  track.insertBefore(lastClone, origSlides[0]);

  var current = 1; // real first slide is at index 1 (after the cloned last)
  var isTransitioning = false;
  var timer;
  var dots = Array.from(document.querySelectorAll('.hero-dot'));

  function setPos(index, animate) {
    track.style.transition = animate ? 'transform 0.7s ease' : 'none';
    track.style.transform = 'translateX(-' + (index * 100) + '%)';
  }

  function updateDots(realIndex) {
    dots.forEach(function (dot, i) {
      dot.classList.toggle('is-active', i === realIndex);
    });
  }

  function goTo(index) {
    if (isTransitioning) return;
    isTransitioning = true;
    current = index;
    setPos(current, true);
    updateDots((current - 1 + total) % total);
  }

  track.addEventListener('transitionend', function () {
    isTransitioning = false;
    if (current <= 0) {
      current = total;
      setPos(current, false);
    } else if (current >= total + 1) {
      current = 1;
      setPos(current, false);
    }
    updateDots((current - 1 + total) % total);
  });

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }

  setPos(current, false);
  updateDots(0);

  dots.forEach(function (dot, i) {
    dot.addEventListener('click', function () {
      clearInterval(timer);
      goTo(i + 1);
      startTimer();
    });
  });

  var prevBtn = document.getElementById('hero-prev');
  var nextBtn = document.getElementById('hero-next');
  if (prevBtn) prevBtn.addEventListener('click', function () { clearInterval(timer); prev(); startTimer(); });
  if (nextBtn) nextBtn.addEventListener('click', function () { clearInterval(timer); next(); startTimer(); });

  // Touch / swipe support
  var touchX = 0;
  slider.addEventListener('touchstart', function (e) { touchX = e.touches[0].clientX; }, { passive: true });
  slider.addEventListener('touchend', function (e) {
    var diff = touchX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) { clearInterval(timer); diff > 0 ? next() : prev(); startTimer(); }
  });

  function startTimer() {
    clearInterval(timer);
    timer = setInterval(next, 5000);
  }

  startTimer();
})();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [],
  "blocks": [
    {
      "type": "category_card",
      "name": "Tarjeta de categoría",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "CATEGORÍA"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "category_card", "settings": { "title": "DESBROZADORAS" } },
        { "type": "category_card", "settings": { "title": "REFACCIONES" } },
        { "type": "category_card", "settings": { "title": "PODADORAS" } },
        { "type": "category_card", "settings": { "title": "MOTOSIERRAS" } },
        { "type": "category_card", "settings": { "title": "ASPERSORES" } },
        { "type": "category_card", "settings": { "title": "MOTOBOMBAS" } }
      ]
    }
  ]
}
{% endschema %}
