<section class="offers">
  {%- for block in section.blocks -%}
    <a
      href="{{ block.settings.link | default: '#' }}"
      class="img__offers"
      {{ block.shopify_attributes }}
    >
      {%- if block.settings.image != blank -%}
        <img
          src="{{ block.settings.image | image_url: width: 800 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
        >
      {%- else -%}
        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </a>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Cuadrícula de Ofertas",
  "blocks": [
    {
      "type": "offer_image",
      "name": "Imagen de Oferta",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Cuadrícula de Ofertas",
      "blocks": [
        { "type": "offer_image" },
        { "type": "offer_image" },
        { "type": "offer_image" },
        { "type": "offer_image" },
        { "type": "offer_image" }
      ]
    }
  ]
}
{% endschema %}
