<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    {%- if template == 'index' -%}
      {{ shop.name }}
    {%- else -%}
      {{ page_title }} | {{ shop.name }}
    {%- endif -%}
  </title>
  <meta name="description" content="{{ page_description | escape }}">
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="app">

  {%- render 'svg-icons' -%}

  {%- section 'header' -%}

  <main class="page">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <!-- ── Cart Drawer ── -->
  <div id="cart-drawer-overlay" class="cart-drawer-overlay" aria-hidden="true"></div>
  <aside id="cart-drawer" class="cart-drawer" aria-hidden="true" role="dialog" aria-label="Carrito">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">
        <svg class="icon" aria-hidden="true" width="22" height="22"><use href="#icon-cart3"></use></svg>
        Mi Carrito
      </h2>
      <button id="cart-drawer-close" class="cart-drawer__close" aria-label="Cerrar carrito">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div id="cart-drawer-body" class="cart-drawer__body">
      <p class="cart-drawer__empty">Tu carrito está vacío.</p>
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__total-row">
        <span>Total</span>
        <span id="cart-drawer-total" class="cart-drawer__total-price">$0.00 MXN</span>
      </div>
      <a href="{{ routes.cart_url }}" class="cart-drawer__btn cart-drawer__btn--outline">Ver carrito</a>
      <a href="{{ routes.checkout_url }}" class="cart-drawer__btn cart-drawer__btn--primary">Proceder al pago →</a>
    </div>
  </aside>

  <script>
    document.addEventListener('DOMContentLoaded', function () {

      /* ── Shuffle carousels ── */
      document.querySelectorAll('.products__carrusel-app').forEach(function (row) {
        var cards = Array.from(row.children);
        for (var i = cards.length - 1; i > 0; i--) {
          var j = Math.floor(Math.random() * (i + 1));
          row.appendChild(cards[j]);
          var tmp = cards[i]; cards[i] = cards[j]; cards[j] = tmp;
        }
      });

      /* ── Cart badge ── */
      function refreshCartBadge() {
        fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            var badge = document.getElementById('cart-count-badge');
            if (!badge) return;
            badge.textContent = cart.item_count;
            badge.style.display = cart.item_count > 0 ? 'flex' : 'none';
          });
      }
      refreshCartBadge();
      window._refreshCartBadge = refreshCartBadge;

      /* ── Cart Drawer ── */
      var drawer = document.getElementById('cart-drawer');
      var overlay = document.getElementById('cart-drawer-overlay');
      var drawerBody = document.getElementById('cart-drawer-body');
      var drawerTotal = document.getElementById('cart-drawer-total');

      function formatMoney(cents) {
        return '$' + (cents / 100).toLocaleString('es-MX', { minimumFractionDigits: 2 }) + ' MXN';
      }

      function renderDrawerItems(cart) {
        if (!cart.items || cart.items.length === 0) {
          drawerBody.innerHTML = '<p class="cart-drawer__empty">Tu carrito está vacío.</p>';
          drawerTotal.textContent = '$0.00 MXN';
          return;
        }
        var html = '<ul class="cart-drawer__list">';
        cart.items.forEach(function (item) {
          html += '<li class="cart-drawer__item" data-key="' + item.key + '">' +
            '<a href="' + item.url + '" class="cart-drawer__item-img-wrap">' +
              '<img src="' + item.image + '" alt="' + item.title.replace(/"/g, '&quot;') + '" class="cart-drawer__item-img" width="72" height="72" loading="lazy">' +
            '</a>' +
            '<div class="cart-drawer__item-info">' +
              '<a href="' + item.url + '" class="cart-drawer__item-title">' + item.product_title + '</a>' +
              (item.variant_title ? '<p class="cart-drawer__item-variant">' + item.variant_title + '</p>' : '') +
              '<div class="cart-drawer__item-row">' +
                '<div class="cart-drawer__qty">' +
                  '<button class="cart-drawer__qty-btn" data-action="decrease" data-key="' + item.key + '" data-qty="' + (item.quantity - 1) + '" aria-label="Reducir cantidad">−</button>' +
                  '<span class="cart-drawer__qty-val">' + item.quantity + '</span>' +
                  '<button class="cart-drawer__qty-btn" data-action="increase" data-key="' + item.key + '" data-qty="' + (item.quantity + 1) + '" aria-label="Aumentar cantidad">+</button>' +
                '</div>' +
                '<span class="cart-drawer__item-price">' + formatMoney(item.final_line_price) + '</span>' +
              '</div>' +
            '</div>' +
            '<button class="cart-drawer__item-remove" data-key="' + item.key + '" data-qty="0" aria-label="Eliminar producto">' +
              '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
            '</button>' +
          '</li>';
        });
        html += '</ul>';
        drawerBody.innerHTML = html;
        drawerTotal.textContent = formatMoney(cart.total_price);

        /* qty / remove buttons inside drawer */
        drawerBody.querySelectorAll('[data-qty]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var key = btn.dataset.key;
            var qty = parseInt(btn.dataset.qty, 10);
            fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: key, quantity: qty })
            })
            .then(function (r) { return r.json(); })
            .then(function (updatedCart) {
              renderDrawerItems(updatedCart);
              refreshCartBadge();
            });
          });
        });
      }

      function openCartDrawer() {
        fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            renderDrawerItems(cart);
            drawer.classList.add('is-open');
            drawer.setAttribute('aria-hidden', 'false');
            overlay.classList.add('is-open');
            overlay.setAttribute('aria-hidden', 'false');
            document.body.classList.add('drawer-open');
          });
      }
      window._openCartDrawer = openCartDrawer;

      function closeCartDrawer() {
        drawer.classList.remove('is-open');
        drawer.setAttribute('aria-hidden', 'true');
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('drawer-open');
      }

      document.getElementById('cart-drawer-close').addEventListener('click', closeCartDrawer);
      overlay.addEventListener('click', closeCartDrawer);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeCartDrawer();
      });

      /* ── AJAX Add to Cart (product cards) ── */
      document.querySelectorAll('.product__card-app form').forEach(function (form) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var btn = form.querySelector('.btn__card-app');
          var origHtml = btn.innerHTML;
          btn.disabled = true;
          btn.innerHTML = '<svg class="icon shopping-icon__card-app" aria-hidden="true"><use href="#icon-cart3"></use></svg> Agregando...';
          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(form.querySelector('[name="id"]').value, 10), quantity: 1 })
          })
          .then(function (r) { return r.json(); })
          .then(function () {
            btn.disabled = false;
            btn.innerHTML = '<svg class="icon shopping-icon__card-app" aria-hidden="true"><use href="#icon-cart3"></use></svg> ¡Agregado!';
            setTimeout(function () { btn.innerHTML = origHtml; btn.disabled = false; }, 1500);
            refreshCartBadge();
            openCartDrawer();
          })
          .catch(function () { btn.disabled = false; btn.innerHTML = origHtml; });
        });
      });

      /* ── Wishlist toggle (product cards) ── */
      document.querySelectorAll('.btn-wishlist-card').forEach(function (btn) {
        var handle = btn.dataset.productHandle;
        var wl = JSON.parse(localStorage.getItem('futool_wishlist') || '[]');
        if (wl.includes(handle)) btn.classList.add('in-wishlist');
        btn.addEventListener('click', function (e) {
          e.stopPropagation();
          var list = JSON.parse(localStorage.getItem('futool_wishlist') || '[]');
          var idx = list.indexOf(handle);
          if (idx === -1) { list.push(handle); btn.classList.add('in-wishlist'); }
          else { list.splice(idx, 1); btn.classList.remove('in-wishlist'); }
          localStorage.setItem('futool_wishlist', JSON.stringify(list));
        });
      });

      /* ── Predictive Search ── */
      (function () {
        var searchInput = document.getElementById('search-input');
        var preview = document.getElementById('search-preview');
        if (!searchInput || !preview) return;

        var debounceTimer;
        var currentQuery = '';
        var activeIndex = -1;

        function formatPrice(cents) {
          return '$' + (cents / 100).toLocaleString('es-MX', { minimumFractionDigits: 2 });
        }

        function renderPreview(resources) {
          var products = (resources.results || []).filter(function (r) { return r.object_type === 'product'; });
          var query = currentQuery;

          if (products.length === 0) {
            preview.innerHTML = '<p class="sp-empty">Sin resultados para "<strong>' + query.replace(/</g,'&lt;') + '</strong>"</p>';
          } else {
            var html = '<ul class="sp-list" role="listbox">';
            products.slice(0, 6).forEach(function (p, i) {
              var img = p.featured_image && p.featured_image.url
                ? '<img src="' + p.featured_image.url + '&width=80" alt="" class="sp-img" width="48" height="48">'
                : '<span class="sp-img-ph"></span>';
              var price = p.price ? '<span class="sp-price">' + formatPrice(p.price) + '</span>' : '';
              html += '<li class="sp-item" role="option" id="sp-item-' + i + '" data-url="' + p.url + '">'
                + '<a href="' + p.url + '" class="sp-link" tabindex="-1">'
                + img
                + '<span class="sp-info"><span class="sp-title">' + p.title + '</span>' + price + '</span>'
                + '</a></li>';
            });
            if (products.length > 6) {
              html += '<li class="sp-more"><a href="/search?type=product&q=' + encodeURIComponent(query) + '">Ver los ' + products.length + ' resultados →</a></li>';
            } else {
              html += '<li class="sp-more"><a href="/search?type=product&q=' + encodeURIComponent(query) + '">Ver todos los resultados →</a></li>';
            }
            html += '</ul>';
            preview.innerHTML = html;
          }
          activeIndex = -1;
          preview.removeAttribute('hidden');
          searchInput.setAttribute('aria-expanded', 'true');
        }

        function closePreview() {
          preview.setAttribute('hidden', '');
          searchInput.setAttribute('aria-expanded', 'false');
          activeIndex = -1;
        }

        function doSearch(q) {
          currentQuery = q;
          fetch('/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=8&resources[options][unavailable_products]=last')
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (currentQuery !== q) return;
              renderPreview(data.resources);
            })
            .catch(function () { closePreview(); });
        }

        searchInput.addEventListener('input', function () {
          var q = searchInput.value.trim();
          clearTimeout(debounceTimer);
          if (q.length < 2) { closePreview(); return; }
          debounceTimer = setTimeout(function () { doSearch(q); }, 250);
        });

        /* keyboard navigation */
        searchInput.addEventListener('keydown', function (e) {
          var items = preview.querySelectorAll('.sp-item');
          if (!items.length) return;
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            activeIndex = (activeIndex + 1) % items.length;
            items.forEach(function (el, i) { el.classList.toggle('sp-active', i === activeIndex); });
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            activeIndex = (activeIndex - 1 + items.length) % items.length;
            items.forEach(function (el, i) { el.classList.toggle('sp-active', i === activeIndex); });
          } else if (e.key === 'Enter' && activeIndex >= 0) {
            e.preventDefault();
            var url = items[activeIndex].dataset.url;
            if (url) window.location.href = url;
          } else if (e.key === 'Escape') {
            closePreview();
          }
        });

        document.addEventListener('click', function (e) {
          if (!document.getElementById('search-wrap').contains(e.target)) closePreview();
        });

        searchInput.addEventListener('focus', function () {
          if (searchInput.value.trim().length >= 2) doSearch(searchInput.value.trim());
        });
      })();

    });
  </script>

</body>
</html>
