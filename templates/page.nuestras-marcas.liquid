<div class="brands-page">
  <div class="brands-header">
    <h1 class="brands-title">{{ page.title }}</h1>
    <p class="brands-subtitle">Trabajamos con las mejores marcas del mercado</p>
  </div>

  <div class="brands-grid">

    <div class="brand-card">
      <div class="brand-logo-wrap">
        <img src="{{ 'brand-stihl.png' | asset_url }}" alt="Stihl" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="brand-fallback">STIHL</span>
      </div>
    </div>

    <div class="brand-card">
      <div class="brand-logo-wrap">
        <img src="{{ 'brand-honda.png' | asset_url }}" alt="Honda" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="brand-fallback">HONDA</span>
      </div>
    </div>

    <div class="brand-card">
      <div class="brand-logo-wrap">
        <img src="{{ 'brand-husqvarna.png' | asset_url }}" alt="Husqvarna" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="brand-fallback">HUSQVARNA</span>
      </div>
    </div>

    <div class="brand-card">
      <div class="brand-logo-wrap">
        <img src="{{ 'brand-makita.png' | asset_url }}" alt="Makita" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="brand-fallback">MAKITA</span>
      </div>
    </div>

    <div class="brand-card">
      <div class="brand-logo-wrap">
        <img src="{{ 'brand-briggs.png' | asset_url }}" alt="Briggs & Stratton" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="brand-fallback">BRIGGS &amp; STRATTON</span>
      </div>
    </div>

    <div class="brand-card">
      <div class="brand-logo-wrap">
        <img src="{{ 'brand-echo.png' | asset_url }}" alt="Echo" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="brand-fallback">ECHO</span>
      </div>
    </div>

    <div class="brand-card">
      <div class="brand-logo-wrap">
        <img src="{{ 'brand-kawasaki.png' | asset_url }}" alt="Kawasaki" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="brand-fallback">KAWASAKI</span>
      </div>
    </div>

    <div class="brand-card">
      <div class="brand-logo-wrap">
        <img src="{{ 'brand-oregon.png' | asset_url }}" alt="Oregon" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <span class="brand-fallback">OREGON</span>
      </div>
    </div>

  </div>
</div>
