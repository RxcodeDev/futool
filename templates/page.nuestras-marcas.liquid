<div class="brands-page">

  <div class="brands-page__header">
    <h1 class="brands-page__title">{{ page.title }}</h1>
    <p class="brands-page__sub">Distribuimos las mejores marcas en maquinaria y herramienta, tenemos fábricas propias y manejamos garantía en gran porción de nuestro material</p>
  </div>

  <div class="brands-grid">

    <div class="brand-card" style="--brand-color: #1A3A6B;">
      <div class="brand-card__accent"></div>
      <div class="brand-card__body">
        <img src="{{ 'brand-futool.png' | asset_url }}" alt="Futool" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
        <span class="brand-name" style="display:none;">FUTOOL</span>
        <p class="brand-desc">Maquinaria y refacciones reforzada de rango pesado, para uso profesional</p>
        <span class="brand-tag" style="background:rgba(26,58,107,0.10);color:#1A3A6B;">Marca propia</span>
      </div>
    </div>

    <div class="brand-card" style="--brand-color: #1B4FA8;">
      <div class="brand-card__accent"></div>
      <div class="brand-card__body">
        <img src="{{ 'brand-kawano.png' | asset_url }}" alt="Kawano" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
        <span class="brand-name" style="display:none;">KAWANO</span>
        <p class="brand-desc">Maquinaria de rango medio y pesado, para uso diario</p>
        <span class="brand-tag" style="background:rgba(27,79,168,0.10);color:#1B4FA8;">Marca propia</span>
      </div>
    </div>

    <div class="brand-card" style="--brand-color: #8B7A2E;">
      <div class="brand-card__accent"></div>
      <div class="brand-card__body">
        <img src="{{ 'brand-palezzi.png' | asset_url }}" alt="Palezzi" class="brand-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
        <span class="brand-name" style="display:none;">PALEZZI</span>
        <p class="brand-desc">Maquinaria de rango ligero, para uso casero</p>
        <span class="brand-tag" style="background:rgba(139,122,46,0.10);color:#8B7A2E;">Marca propia</span>
      </div>
    </div>

  </div>
</div>
